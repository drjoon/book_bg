container_commands:
  01_install_certbot:
    command: |
      if command -v dnf >/dev/null 2>&1; then
        dnf install -y certbot python3-certbot-nginx || true
      elif command -v yum >/dev/null 2>&1; then
        yum install -y certbot python3-certbot-nginx || true
      fi

  02_issue_cert_once:
    command: |
      DOMAIN="book.ap-south-1.elasticbeanstalk.com"
      EMAIL="drjoon@gmail.com"

      # 인증서 재발급은 최초 1회만 수행하되,
      # 배포 시 nginx 설정이 초기화될 수 있어 인증서가 이미 있어도 install은 다시 적용한다.
      if [ -d "/etc/letsencrypt/live/${DOMAIN}" ]; then
        echo "[renew-cert] Existing certificate found for ${DOMAIN}; reinstalling nginx TLS config."
        certbot install --nginx -n --cert-name "${DOMAIN}" || true
      else
        certbot --nginx -n --agree-tos --email "${EMAIL}" -d "${DOMAIN}"
      fi

  03_setup_cron:
    command: |
      echo "0 3 * * * root certbot renew --quiet --post-hook 'systemctl reload nginx'" > /etc/cron.d/certbot-renew
      chmod 644 /etc/cron.d/certbot-renew
